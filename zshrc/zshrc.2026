export PATH="/Users/sratsamy/bin:$PATH"

alias mp='multipass'
alias gitfiles='git log --name-only --pretty="" develop..HEAD | sort | uniq'
alias gbranch="git for-each-ref --sort=-committerdate refs/heads/ --format='%(refname:short)' | sed '1!G;h;$!d'"

